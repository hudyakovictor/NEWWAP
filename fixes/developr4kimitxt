### 2.1 Symmetry Pro (metrics.py l145-234 → robust)
```
def symmetry_score(uv, lm_left, lm_right, conf):
    # Procrustes align fix #2,4
    tform = transform.SimilarityTransform()
    tform.estimate(lm_right, lm_left)  # src,dst order!
    uv_aligned = warp(uv, tform, output_shape=uv.shape[:2], order=3, multichannel=True)
    uv_flip = np.fliplr(uv_aligned)  # Full color fix #1
    mask = conf > 0.65  # Weighted
    regions = get_sym_regions(lm)  # eyes,nose,mouth masks
    dist_left = distance_transform_edt(~regions['left'], distance=2)  # Euclid fix #3,22
    dist_right = distance_transform_edt(~regions['right'], distance=2)
    sym_map = np.abs(dist_left - dist_right) * conf[...,None]
    score = 1 - np.mean(sym_map) / np.max(sym_map)
    return score
```
